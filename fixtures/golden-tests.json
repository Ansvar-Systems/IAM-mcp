      },
      "assertions": {
        "result_not_empty": true,
        "fields_present": ["vendor", "feature", "description"],
        "min_results": 1
      }
    },
    {
      "id": "vendor-004",
      "category": "vendor",
      "description": "Compare MFA across all vendors without filter",
      "tool": "compare_vendors",
      "input": { "feature": "MFA" },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1
      }
    },
