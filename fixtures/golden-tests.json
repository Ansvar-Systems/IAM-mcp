        "min_results": 1
      }
    },
    {
      "id": "emerg-002",
      "category": "emerging",
      "description": "Get all passwordless category emerging technologies",
      "tool": "get_emerging_technology",
      "input": { "category": "passwordless" },
      "assertions": {
