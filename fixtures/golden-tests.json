      }
    },
    {
      "id": "zt-002",
      "category": "architecture",
      "description": "Get Zero Trust guidance for identity at advanced maturity",
      "tool": "get_zero_trust_pattern",
      "input": { "pillar": "identity", "maturity": "advanced" },
      "assertions": {
        "result_not_empty": true,
        "fields_present": ["standards", "patterns"]
      }
    },
    {
      "id": "vendor-001",
      "category": "vendor",
      "description": "Get Azure Entra vendor config for Conditional Access",
      "tool": "get_vendor_config",
      "input": { "vendor": "azure-entra", "feature": "Conditional Access" },
      "assertions": {
        "result_not_empty": true,
        "fields_present": ["vendor", "feature", "description", "best_practices", "common_misconfigurations", "compliance_controls", "equivalent_in"],
        "min_results": 1
      }
    },
    {
      "id": "vendor-002",
      "category": "vendor",
      "description": "Get all Azure Entra vendor configurations (default limit)",
      "tool": "get_vendor_config",
      "input": { "vendor": "azure-entra" },
      "assertions": {
        "result_not_empty": true,
        "min_results": 10
      }
    },
    {
      "id": "vendor-003",
      "category": "vendor",
      "description": "Compare MFA feature across azure-entra and okta vendors",
      "tool": "compare_vendors",
      "input": {
        "feature": "MFA",
